// Prisma v7 Schema
// Usa Supabase Auth para autenticación
// Prisma solo maneja las tablas del schema 'public'

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

// ============================================
// TABLAS DE NEGOCIO (schema: public)
// ============================================

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model public_users {
  id                                                               String                   @id @db.Uuid
  email                                                            String
  name                                                             String
  phone                                                            String?
  created_at                                                       DateTime                 @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                                                       DateTime                 @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  role                                                             String                   @default("user")
  access_codes                                                     access_codes[]
  bookings                                                         bookings[]
  identity_verifications_identity_verifications_reviewed_byTousers identity_verifications[] @relation("identity_verifications_reviewed_byTousers")
  identity_verifications_identity_verifications_user_idTousers     identity_verifications[] @relation("identity_verifications_user_idTousers")
  terms_acceptances                                                terms_acceptances[]

  @@index([role], map: "idx_users_role")
  @@index([email])
  @@map("users")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model properties {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  address        String
  city           String
  region         String
  base_price_clp Int
  amenities      String[]
  images         String[]
  capacity       Int?             @default(1)
  bedrooms       Int?             @default(1)
  bathrooms      Int?             @default(1)
  is_active      Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  lock_provider  String?
  lock_device_id String?
  lock_enabled   Boolean?         @default(false)
  access_codes   access_codes[]
  bookings       bookings[]
  discount_rules discount_rules[]

  @@index([city], map: "idx_properties_city")
  @@index([is_active], map: "idx_properties_is_active")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model bookings {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String                   @db.Uuid
  property_id            String                   @db.Uuid
  check_in               DateTime                 @db.Date
  check_out              DateTime                 @db.Date
  days                   Int
  price_per_day_clp      Int
  total_price_clp        Int
  payment_status         String?                  @default("pending")
  identity_verified      Boolean?                 @default(false)
  access_code            String?
  access_code_expires_at DateTime?                @db.Timestamptz(6)
  status                 String?                  @default("pending")
  created_at             DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?                @default(now()) @db.Timestamptz(6)
  base_price_clp         Int
  discount_percentage    Decimal?                 @default(0) @db.Decimal(5, 2)
  discount_amount_clp    Int?                     @default(0)
  access_codes           access_codes[]
  properties             properties               @relation(fields: [property_id], references: [id], onUpdate: NoAction)
  users                  public_users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  identity_verifications identity_verifications[]
  terms_acceptances      terms_acceptances[]

  @@index([check_in, check_out], map: "idx_bookings_dates")
  @@index([property_id], map: "idx_bookings_property_id")
  @@index([status], map: "idx_bookings_status")
  @@index([user_id], map: "idx_bookings_user_id")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model access_codes {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id       String        @db.Uuid
  property_id      String        @db.Uuid
  code             String
  valid_from       DateTime      @db.Timestamptz(6)
  valid_until      DateTime      @db.Timestamptz(6)
  is_active        Boolean?      @default(true)
  revoked_at       DateTime?     @db.Timestamptz(6)
  revoked_by       String?       @db.Uuid
  tuya_lock_id     String?
  tuya_response    Json?
  created_at       DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?     @default(now()) @db.Timestamptz(6)
  lock_password_id String?
  lock_sync_status String?       @default("pending")
  lock_error       String?
  lock_synced_at   DateTime?     @db.Timestamptz(6)
  bookings         bookings      @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties       properties    @relation(fields: [property_id], references: [id], onUpdate: NoAction)
  users            public_users? @relation(fields: [revoked_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([booking_id], map: "idx_access_codes_booking_id")
  @@index([is_active], map: "idx_access_codes_is_active")
  @@index([property_id], map: "idx_access_codes_property_id")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model discount_rules {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id         String?     @db.Uuid
  min_days            Int
  max_days            Int
  discount_percentage Decimal     @db.Decimal(5, 2)
  is_active           Boolean?    @default(true)
  created_at          DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?   @default(now()) @db.Timestamptz(6)
  properties          properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([property_id], map: "idx_discount_rules_property")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model identity_verifications {
  id                                              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                                         String        @db.Uuid
  booking_id                                      String?       @db.Uuid
  document_front_url                              String
  document_back_url                               String?
  selfie_url                                      String
  status                                          String?       @default("pending")
  reviewed_by                                     String?       @db.Uuid
  reviewed_at                                     DateTime?     @db.Timestamptz(6)
  rejection_reason                                String?
  face_match_score                                Float?
  facepp_response                                 Json?
  created_at                                      DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at                                      DateTime?     @default(now()) @db.Timestamptz(6)
  bookings                                        bookings?     @relation(fields: [booking_id], references: [id], onUpdate: NoAction)
  users_identity_verifications_reviewed_byTousers public_users? @relation("identity_verifications_reviewed_byTousers", fields: [reviewed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_identity_verifications_user_idTousers     public_users  @relation("identity_verifications_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_identity_verifications_status")
  @@index([user_id], map: "idx_identity_verifications_user_id")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model terms_acceptances {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String       @db.Uuid
  booking_id    String?      @db.Uuid
  accepted_at   DateTime?    @default(now()) @db.Timestamptz(6)
  ip_address    String?
  user_agent    String?
  terms_version String?      @default("v1.0")
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  bookings      bookings?    @relation(fields: [booking_id], references: [id], onUpdate: NoAction)
  users         public_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([booking_id], map: "idx_terms_acceptances_booking_id")
  @@index([user_id], map: "idx_terms_acceptances_user_id")
  @@schema("public")
}
